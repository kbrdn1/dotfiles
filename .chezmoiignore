~/.zsh_secrets

# ===================================================================
# Claude Code - Runtime Data (NEVER VERSION)
# ===================================================================
.claude/logs/
.claude/history.jsonl
.claude/todos/
.claude/file-history/
.claude/shell-snapshots/
.claude/statsig/
.claude/telemetry/
.claude/usage-data/
.claude/debug/
.claude/backups/
.claude/cache/
.claude/paste-cache/
.claude/downloads/
.claude/ide/
.claude/plans/
.claude/tasks/
.claude/teams/
.claude/session-env/
.claude/mcp-needs-auth-cache.json
.claude/stats-cache.json
.claude/.update_check
.claude/.DS_Store

# Claude Plugins - Auto-generated (too large)
.claude/plugins/cache/
.claude/plugins/marketplaces/

# ===================================================================
# Claude Projects - Conversations & Runtime (Machine Specific)
# ===================================================================
.claude/projects/**/
.claude/projects/**/*.jsonl

# PRIVATE projects (sensitive personal data)
.claude/projects/*cv-exporter*/
.claude/projects/*personal*/
.claude/projects/*private*/

# Temporary/cache files in all projects
.claude/projects/**/node_modules/
.claude/projects/**/.git/
.claude/projects/**/.env.local
.claude/projects/**/dist/
.claude/projects/**/build/
.claude/projects/**/*.log

# ===================================================================
# Sensitive patterns (across all projects)
# ===================================================================
**/*secret*
**/*password*
**/*.pem
**/*.key
**/id_rsa*

# ===================================================================
# Config exclusions
# ===================================================================
# Nvim - auto-generated
.config/nvim/lazy-lock.json
.config/nvim/.git/

# Superfile - auto-generated themes
.config/superfile/theme/
.config/superfile/config.toml.bak-*

# Lazysql - runtime data
.config/lazysql/history/
.config/lazysql/saved_queries/

# Yazi - auto-backup files
.config/yazi/*.toml-[0-9]*
.config/yazi/.taplo.toml

# Sketchybar - archives and runtime
.config/sketchybar/archive/
.config/sketchybar/.aerospace_padding_state
.config/sketchybar/.theme_preference
.config/sketchybar/.DS_Store
.config/sketchybar/plugins/.DS_Store

# Aerospace - backup files
.config/aerospace/aerospace.toml.backup.*
.config/aerospace/backups/

# Bat - cache
.config/bat/.DS_Store
.config/bat/themes/.DS_Store

# Opencode - not tracked (node_modules)
.config/opencode/

# General
**/.DS_Store
**/*.bak
**/*.bak-*
