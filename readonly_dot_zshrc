# Spawn Claude Code in the Ghostty-managed tmux main session for a project path.
function ccp() {
  local dir="${1:-$PWD}" base cmd
  dir="$(cd "$dir" && pwd)" || return
  base="$(basename "$dir")"
  cmd="claude --dangerously-skip-permissions"

  if [[ -n "$TMUX" ]]; then
    tmux new-window -c "$dir" -n "cc:$base" "$cmd"
    return
  fi

  if ! tmux has-session -t main 2>/dev/null; then
    open -na Ghostty.app >/dev/null 2>&1 || return
    for _ in {1..30}; do
      tmux has-session -t main 2>/dev/null && break
      sleep 0.2
    done
  fi

  if tmux has-session -t main 2>/dev/null; then
    tmux new-window -t main -c "$dir" -n "cc:$base" "$cmd"
  else
    echo "tmux session 'main' not found. Open Ghostty, then retry: ccp \"$dir\"" >&2
    return 1
  fi
}

# edit-* helpers for nix-managed files: open home.nix at the right section
# (zed accepts file:line:column to jump straight to a location)
_edit_nix_section() {
  local pattern="$1" f="$HOME/nix-config/home.nix" ln
  ln=$(grep -n "$pattern" "$f" | head -1 | cut -d: -f1)
  command "$EDITOR" "$f${ln:+:$ln}"
}
edit-zsh()  { _edit_nix_section '^  programs\.zsh = {'; }
edit-tmux() { _edit_nix_section '^  programs\.tmux = {'; }
edit-git()  { _edit_nix_section '^  programs\.git = {'; }

