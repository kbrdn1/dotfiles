      // ── Tools / Tasks (space t) ────────────────────────────────────────────
      "space t n": ["task::Spawn", { "task_name": "IDE: Neovim" }],
      "space t f": ["task::Spawn", { "task_name": "Files: FZF" }],
      "space t y": ["task::Spawn", { "task_name": "Files: Yazi" }],
      "space t r": ["task::Spawn", { "task_name": "Files: Rename Files (FZF)" }],
