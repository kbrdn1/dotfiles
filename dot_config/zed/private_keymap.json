      "space A": "editor::FindAllReferences",
      "space @": "editor::RestartLanguageServer",

      // ── Git (space g) ──────────────────────────────────────────────────────
      "space g g": "git_panel::ToggleFocus",
      "space G G": ["task::Spawn", { "task_name": "Git: Lazygit" }],
      "space g b": "git::Blame",
      "space g D": ["task::Spawn", { "task_name": "Git: Lumen diff" }],
      "space g d": "git::Diff",
