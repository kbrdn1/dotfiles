// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  // ══════════════════════════════════════════════════════════════════════
  // Theme & Appearance
  // ══════════════════════════════════════════════════════════════════════
  "theme": "Claude Dark (Pure)",
  "icon_theme": "Catppuccin Macchiato",
  "experimental.theme_overrides": {
    "background.appearance": "blurred",
  },
  "redact_private_values": true,
  "current_line_highlight": "all",
  "bottom_dock_layout": "contained",

  // ══════════════════════════════════════════════════════════════════════
  // Font Settings
  // ══════════════════════════════════════════════════════════════════════
  // "ui_font_family": "Monaspace Argon Var",
  "ui_font_family": "OperatorMonoLig Nerd Font",
  "ui_font_size": 14.75,
  "ui_font_features": {
    "liga": true, // www
  },
  "ui_font_weight": 400,
  "buffer_font_family": "OperatorMonoLig Nerd Font",
  "buffer_font_size": 14.0,
  "buffer_font_fallbacks": ["CaskaydiaCove Nerd Font"],
  "buffer_font_weight": 400,
  "buffer_line_height": {
    "custom": 1.825,
  },
  "buffer_font_features": {
    "liga": true, // www /// !! ;;
    "zero": true, // 0
    "cv01": true, // a
    "cv06": true, // i
    "cv27": true, // []
    "cv31": true, // ()
    "ss01": true, // ===
    "ss02": true, // >= <=
    "ss03": true, // <--> <->
    "ss04": true, // </> </ <>
    "ss05": true, // [|  [] /\ |>
    "ss06": true, // ### +++ &&&
    "ss07": true, // -:- =:= ::> :::
    "ss08": true, // ..= ..- ..<
    "ss09": true, // <=> <<= >>=
    "ss10": true, // fi ft
    "ordn": false, // No. 1st 2nd
    "clig": true, // _|_
    "salt": false, // Stylistic Alternates
    "calt": true, // Contextual Alternates (fi -> ﬁ)
  },
  "agent_buffer_font_size": 13.0,
  "agent_ui_font_size": 13.75,

  // ══════════════════════════════════════════════════════════════════════
  // Editor Behavior
  // ══════════════════════════════════════════════════════════════════════
  "vim_mode": true,
  "base_keymap": "VSCode",
  "active_pane_modifiers": {
    "border_size": 0.4,
    "inactive_opacity": 0.45,
  },
  // "enable_experimental_live_diffs": true,
  "tab_size": 2,
  "minimap": {
    "show": "auto",
  },
  "relative_line_numbers": "enabled",
  "preferred_line_length": 100,
  "soft_wrap": "preferred_line_length",
  "show_whitespaces": "selection",
  "ensure_final_newline_on_save": false,
  "remove_trailing_whitespace_on_save": true,
  "format_on_save": "off",
  "formatter": "prettier",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "line_indicator_format": "long",
  "expand_excerpt_lines": 8,
  "excerpt_context_lines": 8,
  "colorize_brackets": true,
  "centered_layout": {
    "left_padding": 0.075,
    "right_padding": 0.075,
    // "left_padding": 0.004,
    // "right_padding": 0.004,
  },
  "diff_view_style": "unified",
  "horizontal_scroll_margin": 3,
  "load_direnv": "direct",
  "sticky_scroll": {
    "enabled": true,
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 0,
  },
  "hide_mouse": "on_typing_and_movement",
  "whitespace_map": {
    "space": "·",
    "tab": "→",
  },
  "document_symbols": "on",

  // ══════════════════════════════════════════════════════════════════════
  // UI Elements
  // ══════════════════════════════════════════════════════════════════════
  "tab_bar": {
    "show": true,
  },
  "title_bar": {
    "show_branch_icon": true,
    "show_branch_name": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_user_picture": true,
  },
  "status_bar": {
    "active_encoding_button": "non_utf8",
    "active_language_button": true,
    "cursor_position_button": true,
    "experimental.show": true,
  },
  "search": {
    "button": true,
    "case_sensitive": false,
    "whole_word": false,
    "regex": false,
    "include_ignored": false,
  },
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
    "activate_on_close": "history",
    "show_close_button": "hover",
    "show_diagnostics": "all",
  },
  "toolbar": {
    "selections_menu": true,
    "breadcrumbs": true,
    "quick_actions": true,
  },
  "file_finder": {
    "modal_max_width": "medium",
  },
  "preview_tabs": {
    "enabled": true,
    "enable_preview_file_from_code_navigation": true,
    "enable_preview_from_file_finder": true,
    "enable_keep_preview_on_code_navigation": true,
    "enable_preview_from_multibuffer": true,
    "enable_preview_from_project_panel": true,
    "enable_preview_multibuffer_from_code_navigation": true,
  },
  "project_panel": {
    "default_width": 300,
    "dock": "right",
    "auto_open": {
      "on_paste": false,
      "on_create": false,
    },
    "bold_folder_labels": true,
    "drag_and_drop": true,
    "hide_gitignore": false,
    "hide_hidden": false,
    "hide_root": false,
    "sort_mode": "files_first",
    "entry_spacing": "standard",
    "indent_size": 15,
    "git_status": true,
    "auto_fold_dirs": true,
    "auto_reveal_entries": true,
    "button": true,
    "file_icons": true,
    "folder_icons": true,
    "show_diagnostics": "all",
    "scrollbar": {
      "show": "auto",
    },
    "indent_guides": {
      "show": "always",
    },
  },
  "outline_panel": {
    "auto_fold_dirs": true,
    "auto_reveal_entries": true,
    "button": true,
    "default_width": 300,
    "dock": "left",
    "expand_outlines_with_depth": 2,
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_guides": {
      "show": "always",
    },
    "indent_size": 2,
    "scrollbar": {
      "show": "auto",
    },
  },
  "git_panel": {
    "tree_view": true,
    "sort_by_path": true,
    "button": true,
    "collapse_untracked_diff": true,
    "default_width": 300,
    "dock": "left",
    "fallback_branch_name": "dev",
    "scrollbar": {
      "show": "auto",
    },
    "status_style": "icon",
  },
  "debugger": {
    "dock": "left",
  },

  // ══════════════════════════════════════════════════════════════════════
  // Code Intelligence
  // ══════════════════════════════════════════════════════════════════════
  // "semantic_index": {
  //   "enabled": true
  // },
  "inlay_hints": {
    "enabled": true,
    "show_other_hints": true,
    "show_parameter_hints": true,
    "show_type_hints": true,
    "scroll_debounce_ms": 50,
    "show_background": false,
    "edit_debounce_ms": 0,
    "toggle_on_modifiers_press": {
      "platform": true,
      "function": true,
    },
  },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 300,
      "padding": 2,
      "min_column": 0,
      "max_severity": null,
    },
    "button": true,
    "lsp_pull_diagnostics": {
      "debounce_ms": 300,
      "enabled": true,
    },
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "background_coloring": "disabled",
    "line_width": 1,
    "active_line_width": 2,
  },

  // ══════════════════════════════════════════════════════════════════════
  // AI Assistance
  // ══════════════════════════════════════════════════════════════════════
  "agent": {
    "dock": "left",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
    "default_profile": "development",
    "tool_permissions": {
      "default": "allow",
    },
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": true,
    "profiles": {
      "development": {
        "name": "Development",
        "tools": {
          "web_search": true,
          "rename": true,
          "contents": true,
          "code_actions": true,
          "thinking": true,
          "symbol_info": true,
          "grep": true,
          "read_file": true,
          "find_path": true,
          "open": true,
          "now": true,
          "move_path": true,
          "list_directory": true,
          "edit_file": true,
          "fetch": true,
          "diagnostics": true,
          "delete_path": true,
          "create_directory": true,
          "create_file": true,
          "copy_path": true,
          "code_symbols": true,
          "batch_tool": true,
          "terminal": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "mcp-server-sequential-thinking": {
            "tools": {
              "sequentialthinking": true,
            },
          },
          "mcp-server-github": {
            "tools": {
              "github": true,
            },
            "settings": {
              "github_personal_access_token": "",
            },
          },
        },
      },
      "write": {
        "name": "Write",
        "tools": {
          "terminal": true,
          "batch_tool": true,
          "code_symbols": true,
          "copy_path": false,
          "create_file": true,
          "delete_path": false,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": false,
          "move_path": false,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "symbol_info": true,
          "thinking": true,
          "create_directory": false,
        },
        "enable_all_context_servers": true,
        "context_servers": {
          "mcp-server-sequential-thinking": {
            "tools": {
              "sequentialthinking": true,
            },
          },
        },
      },
      "ask": {
        "name": "Ask",
        "tools": {
          "symbol_info": true,
          "open": true,
          "delete_path": false,
          "create_file": false,
          "create_directory": false,
          "copy_path": false,
          "code_symbols": false,
          "batch_tool": false,
          "diagnostics": false,
          "fetch": true,
          "list_directory": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "thinking": true,
          "terminal": false,
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "mcp-server-sequential-thinking": {
            "tools": {
              "sequentialthinking": true,
            },
          },
        },
      },
    },
  },
  "agent_servers": {
    "mistral-vibe": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
    "github-copilot": {
      "type": "registry",
    },
    "claude": {
      "favorite_config_option_values": {
        "model": ["default"],
      },
      "favorite_models": ["opus"],
    },
    "your_agent": {
      "type": "custom",
      "command": "path_to_executable",
      "args": [],
      "env": {},
    },
  },
  "context_servers": {
    "mcp-server-sequential-thinking": {
      "enabled": true,
      "settings": {},
    },
    "mcp-server-exa-search": {
      "enabled": false,
      "settings": {},
    },
    "prisma-mcp": {
      "enabled": false,
      "settings": {},
    },
    "github-activity-summarizer": {
      "enabled": false,
      "settings": {},
    },
    "mcp-server-context7": {
      "enabled": false,
      "settings": {
        "context7_api_key": "CTX7_PERSONAL_ACCESS_TOKEN",
      },
    },
    "mcp-server-github": {
      "enabled": false,
      "settings": {
        "github_personal_access_token": "GITHUB_PERSONAL_ACCESS_TOKEN",
      },
    },
    "browser-tools-context-server": {
      "enabled": true,
      "settings": {},
    },
    "serena-context-server": {
      "enabled": true,
      "settings": {
        "python_executable": "/usr/bin/python3",
      },
    },
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
    "disabled_globs": [],
    "enabled_in_text_threads": true,
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
    "codestral": {
      "api_url": "https://codestral.mistral.ai",
      "model": "codestral-latest",
      "max_tokens": 1000,
    },
  },
  "show_edit_predictions": true,

  // ══════════════════════════════════════════════════════════════════════
  // File Handling
  // ══════════════════════════════════════════════════════════════════════
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
    "Shell Script": [
      "sh",
      "bash",
      "zsh",
      "fish",
      "ksh",
      "csh",
      "tcsh",
      "sh.*",
      "bash.*",
      "zsh.*",
      "fish.*",
      "ksh.*",
      "csh.*",
      "tcsh.*",
    ],
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/node_modules",
    "**/dist",
    "**/.idea",
    "**/.vscode",
    "**/__pycache__",
    "**/.__mocks__",
    "**/out",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.next",
    "**/.nuxt",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
  ],

  // ══════════════════════════════════════════════════════════════════════
  // Git Integration
  // ══════════════════════════════════════════════════════════════════════
  "git": {
    "git_gutter": "tracked_files",
    "hunk_style": "staged_hollow",
    "inline_blame": {
      "enabled": true,
      "padding": 0,
      "min_column": 100,
      "show_commit_summary": true,
      "delay_ms": 0,
    },
    "gutter_debounce": 0,
  },
  "gutter": {
    "min_line_number_digits": 0,
  },

  // ══════════════════════════════════════════════════════════════════════
  // Language & LSP Settings
  // ══════════════════════════════════════════════════════════════════════
  "use_smartcase_search": true,
  "lsp": {
    "discord_presence": {
      "initialization_options": {
        // application id for the rich presence (required, keep it if you don't know what you're doing)
        "application_id": "1263505205522337886",
        // Base url for all language icons
        "base_icons_url": "https://raw.githubusercontent.com/xhyrom/zed-discord-presence/main/assets/icons/",

        "state": "Working on {filename}",
        "details": "In {workspace}",
        // URL for large image
        "large_image": "{base_icons_url}/{language}.png",
        "large_text": "{language:u}", // :u makes first letter upper-case
        // URL for small image
        "small_image": "{base_icons_url}/zed.png",
        "small_text": "Zed",

        // Rules - disable presence in some workspaces
        "rules": {
          "mode": "blacklist", // or whitelist
          "paths": ["absolute path"],
        },

        "git_integration": true,
      },
    },
    "eslint": {
      "settings": {
        "codeActionOnSave": {
          "rules": ["import/order"],
        },
      },
      "initialization_options": {
        "autoFix": true,
        "format": true,
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy", // rust-analyzer.check.command (default: "check")
        },
      },
    },
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": false,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": true,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true,
        },
      },
    },
  },
  "languages": {
    "Rust": {
      "formatter": {
        "external": {
          "command": "rustfmt",
          "arguments": ["--emit=stdout"],
        },
      },
    },
    "Python": {
      "formatter": {
        "external": {
          "command": "black",
          "arguments": ["-"],
        },
      },
    },
    "Markdown": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "JSON": {
      "formatter": [
        {
          "code_action": "source.fixAll",
        },
        {
          "external": {
            "command": "prettier",
            "arguments": ["--stdin-filepath", "{buffer_path}"],
          },
        },
      ],
    },
    "PHP": {
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll": true,
      },
      "language_servers": ["intelephense", "!phpactor", "..."],
    },
    "TypeScript": {
      "formatter": [
        {
          "code_action": "source.organizeImports",
        },
        {
          "code_action": "source.fixAll",
        },
        {
          "external": {
            "command": "prettier",
            "arguments": ["--stdin-filepath", "{buffer_path}"],
          },
        },
      ],
    },
    "TSX": {
      "formatter": [
        {
          "code_action": "source.organizeImports",
        },
        {
          "code_action": "source.fixAll",
        },
        {
          "external": {
            "command": "prettier",
            "arguments": ["--stdin-filepath", "{buffer_path}"],
          },
        },
      ],
    },
    "JavaScript": {
      "formatter": [
        {
          "code_action": "source.fixAll.eslint",
        },
        {
          "code_action": "source.organizeImports",
        },
        {
          "external": {
            "command": "prettier",
            "arguments": ["--stdin-filepath", "{buffer_path}"],
          },
        },
      ],
    },
  },

  // ══════════════════════════════════════════════════════════════════════
  // Terminal Settings
  // ══════════════════════════════════════════════════════════════════════
  "terminal": {
    "dock": "bottom",
    "default_height": 325,
    "button": true,
    // "font_family": "CaskaydiaCove Nerd Font",
    // "font_family": "Monaspace Krypton Frozen",
    "font_family": "OperatorMonoLig Nerd Font",
    "font_fallbacks": ["CaskaydiaCove Nerd Font"],
    "font_size": 14,
    "font_weight": 320.0,
    // "font_weight": 300,
    "line_height": {
      "custom": 1.2,
    },
    "font_features": {
      "liga": true, // www /// !! ;;
      "zero": true, // 0
      "cv01": true, // a
      "cv06": true, // i
      "cv27": true, // []
      "CV31": true, // ()
      "ss01": true, // ===
      "ss02": true, // >= <=
      "ss03": true, // <--> <->
      "ss04": true, // </> </ <>
      "ss05": true, // [|  [] /\ |>
      "ss06": true, // ### +++ &&&
      "ss07": true, // -:- =:= ::> :::
      "ss08": true, // ..= ..- ..<
      "ss09": true, // <=> <<= >>=
      "ss10": true, // fi ft
      "ordn": false, // No. 1st 2nd
      "clig": true, // _|_
      "salt": false, // Stylistic Alternates
      "calt": true, // Contextual Alternates (fi -> ﬁ)
    },
    "blinking": "on",
    "copy_on_select": true,
    "shell": {
      "program": "zsh",
    },
    "toolbar": {
      "breadcrumbs": true,
    },
    "working_directory": "current_project_directory",
    "detect_venv": {
      "on": {
        "directories": [".env", ".venv", "venv", "env", "envs"],
        "activate_script": "default",
      },
    },
  },

  // ══════════════════════════════════════════════════════════════════════
  // Other Settings
  // ══════════════════════════════════════════════════════════════════════
  "journal": {
    "path": "~",
    "hour_format": "hour24",
  },
  "jupyter": {
    "kernel_selections": {
      "typescript": "deno",
      "javascript": "deno",
      "python": "python3",
    },
  },
}
