  // ============================================================================
  // File & Explorer Tools
  // ============================================================================
  {
    "label": "Explorer: Superfile",
    "command": "superfile",
    "hide": "on_success",
    "reveal_target": "center",
    "use_new_terminal": true,
    "show_summary": false,
    "allow_concurrent_runs": true,
  },
  {
    "label": "Explorer: Yazi",
    "command": "cd $ZED_WORKTREE_ROOT && yazi",
    "use_new_terminal": true,
    "reveal": "always",
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["-c"],
      },
    },
    "allow_concurrent_runs": false,
    "hide": "on_success",
    "reveal_target": "center",
  },
  {
    "label": "Files: FZF",
    "command": "cd $ZED_WORKTREE_ROOT && fzf --style full --border-label ' FZF ' --header-label ' File Type ' --preview 'bat -n --color=always --line-range :500 {}' --bind 'focus:transform-preview-label:[[ -n {} ]] && printf \" [%s] \" {}' --bind 'focus:+transform-header:file --brief {} || echo \"No file selected\"' --bind 'ctrl-r:change-list-label( Reloading the list )+reload(sleep 2; git ls-files)' --bind 'enter:execute($EDITOR {})' --color 'border:#494d64,label:#cad3f5' --color 'preview-border:#8aadf4,preview-label:#b7bdf8' --color 'list-border:#a6da95,list-label:#a6da95' --color 'input-border:#ed8796,input-label:#f5a9b8' --color 'header-border:#7dc4e4,header-label:#91d7e3'; true",
    "use_new_terminal": true,
    "reveal": "always",
    "hide": "on_success",
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["-c"],
      },
    },
    "allow_concurrent_runs": false,
    "reveal_target": "center",
  },
  {
    "label": "Files: Rename Files (FZF)",
    "command": "cd $ZED_WORKTREE_ROOT && FILE=$(find . -type f | fzf --prompt='Select file to rename: ' --height=100% --reverse --border) && [ -n \"$FILE\" ] && echo \"Current file: $FILE\" && echo -n \"$FILE\" | pbcopy && printf 'New name: ' && read -e NEW_NAME && [ -n \"$NEW_NAME\" ] && [ \"$FILE\" != \"$NEW_NAME\" ] && mv \"$FILE\" \"$NEW_NAME\" && echo \"Renamed to: $NEW_NAME\" || echo \"Rename cancelled or failed\"",
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["-c"],
      },
    },
    "use_new_terminal": true,
    "reveal": "always",
    "show_summary": true,
    "allow_concurrent_runs": false,
  },
  {
    "label": "Files: Generate Project Structure file",
    "command": "cd $ZED_WORKTREE_ROOT && eza --tree --level=5 --git-ignore --ignore-glob=\"vendor|node_modules|.git|storage|bootstrap/cache|*.log\" > project-structure.txt",
    "use_new_terminal": true,
    "reveal": "no_focus",
    "shell": {
      "with_arguments": {
        "program": "/bin/bash",
        "args": ["-c"],
      },
    },
    "allow_concurrent_runs": false,
    "hide": "on_success",
    "reveal_target": "dock",
  },

