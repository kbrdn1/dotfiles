[
  // ============================================================================
  // IDE, Terminal & Shell Tools
  // ============================================================================
  {
    "label": "Terminal: Tmux (attach or new)",
    "command": "tmux new-session -A -s main",
    "shell": {
      "with_arguments": {
        "program": "/bin/zsh",
        "args": ["-lic"],
      },
    },
    "hide": "on_success",
    "reveal_target": "center",
    "use_new_terminal": true,
    "show_summary": false,
    "allow_concurrent_runs": true,
  },
  {
    "label": "Terminal: Tmux (new session)",
    "command": "tmux new-session -s \"session-$(date +%Y%m%d-%H%M%S)\"",
    "shell": {
      "with_arguments": {
        "program": "/bin/zsh",
        "args": ["-lic"],
      },
    },
    "hide": "on_success",
    "reveal_target": "center",
    "use_new_terminal": true,
    "show_summary": false,
    "allow_concurrent_runs": true,
  },
  {
